#!/usr/bin/env bash
set -euo pipefail

# HN post summarizer: article via Perplexity fetch_url + comments via claude -p
# Usage: hn-summarize [HN_URL_or_ID]   (prompts for URL if no argument given)

PERPLEXITY_API_URL="https://api.perplexity.ai/v1/agent"
PERPLEXITY_MODEL="anthropic/claude-sonnet-4-6"
CHROME="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
TMP_PDF="/tmp/hn_comments_$$.pdf"

# --- Helpers ---

die() { echo "hn-summarize: $*" >&2; exit 1; }

cleanup() { rm -f "$TMP_PDF"; }
trap cleanup EXIT

# --- Args ---

if [[ $# -gt 1 ]]; then
  echo "Usage: hn-summarize [HN_URL_or_ID]" >&2
  echo "  e.g. hn-summarize 47566865" >&2
  echo "  e.g. hn-summarize https://news.ycombinator.com/item?id=47566865" >&2
  echo "  (no argument: prompts for URL)" >&2
  exit 1
fi

if [[ $# -eq 1 ]]; then
  INPUT="$1"
else
  read -r -p "HN URL or item ID: " INPUT
fi

# Normalise to full URL
if [[ "$INPUT" =~ ^[0-9]+$ ]]; then
  HN_URL="https://news.ycombinator.com/item?id=${INPUT}"
else
  HN_URL="$INPUT"
fi

[[ -z "${PERPLEXITY_API_KEY:-}" ]] && die "PERPLEXITY_API_KEY not set"
command -v claude >/dev/null 2>&1 || die "'claude' not found in PATH"
[[ -x "$CHROME" ]] || die "Google Chrome not found at: $CHROME"

# --- Step 1: extract article URL from HN page ---

echo "[1/4] Fetching HN page DOM..." >&2
ARTICLE_URL=$("$CHROME" --headless --dump-dom "$HN_URL" 2>/dev/null \
  | python3 -c "
import sys, re
html = sys.stdin.read()
m = re.search(r'class=\"titleline\"[^>]*>.*?href=\"([^\"]+)\"', html)
print(m.group(1) if m else '')
")

# --- Step 2 + 3 in parallel: Perplexity article summary & PDF render ---

echo "[2/4] Rendering comments to PDF and fetching article (parallel)..." >&2

perplexity_summary=""
if [[ -n "$ARTICLE_URL" ]]; then
  PERP_PAYLOAD=$(jq -n \
    --arg model "$PERPLEXITY_MODEL" \
    --arg url "$ARTICLE_URL" \
    '{
      model: $model,
      input: ("Fetch and summarize the full content of this article: " + $url),
      tools: [{type: "fetch_url"}],
      instructions: "Use fetch_url to retrieve the full article. Provide a detailed summary covering: main argument, key points, anecdotes, data, and conclusions.",
      max_output_tokens: 2048
    }')

  curl -s "$PERPLEXITY_API_URL" \
    -H "Authorization: Bearer $PERPLEXITY_API_KEY" \
    -H "Content-Type: application/json" \
    -d "$PERP_PAYLOAD" \
    > /tmp/hn_perp_$$.json &
  PERP_PID=$!
fi

"$CHROME" --headless --print-to-pdf="$TMP_PDF" "$HN_URL" 2>/dev/null &
PDF_PID=$!

wait $PDF_PID
echo "[3/4] PDF ready. Waiting for Perplexity..." >&2

if [[ -n "$ARTICLE_URL" ]]; then
  wait $PERP_PID
  perplexity_summary=$(jq -r '.output[] | select(.type == "message") | .content[].text' /tmp/hn_perp_$$.json 2>/dev/null || echo "(Perplexity returned no content)")
  rm -f /tmp/hn_perp_$$.json
else
  perplexity_summary="*(Self-post / Ask HN — no external article)*"
fi

# --- Step 4: summarize comments via claude -p ---

echo "[4/4] Summarizing comments with claude -p..." >&2

COMMENTS_SUMMARY=$(claude -p \
  "Use the Read tool to read the PDF at ${TMP_PDF}, then summarize the Hacker News discussion.

Focus on:
- The dominant themes and opinions
- Notable debates or disagreements
- Highly upvoted or insightful individual comments
- Any corrections to the article or additional context provided by commenters

Be concise but comprehensive. Use markdown." \
  --model claude-sonnet-4-6 \
  --allowedTools "Read")

# --- Output ---

cat <<EOF

## 📰 Article Summary

${perplexity_summary}

---

## 💬 HN Comments Summary

${COMMENTS_SUMMARY}
EOF
