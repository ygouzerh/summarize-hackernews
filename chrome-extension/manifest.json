{
  "manifest_version": 3,
  "name": "HN Summarizer",
  "version": "1.0.0",
  "description": "Summarize Hacker News posts with article summary + comments analysis",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.perplexity.ai/*",
    "https://hn.algolia.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://news.ycombinator.com/*"],
      "js": ["content-script.js"],
      "css": ["content-script.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["results.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
